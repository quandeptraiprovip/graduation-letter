# Google Sheets (lời chúc + RSVP + metadata chữ ký)
GOOGLE_SHEETS_ID=
# Cách 1 (khuyên dùng): minify file JSON key rồi dán một dòng:
#   GOOGLE_SERVICE_ACCOUNT_JSON=$(cat path/to/key.json | jq -c .)
GOOGLE_SERVICE_ACCOUNT_JSON=
# Cách 2: tách email + key; mỗi xuống dòng trong PEM = \n (hai ký tự \ và n)
GOOGLE_CLIENT_EMAIL=
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# Vercel Blob — lưu file PNG chữ ký (bắt buộc trên Vercel)
BLOB_READ_WRITE_TOKEN=
